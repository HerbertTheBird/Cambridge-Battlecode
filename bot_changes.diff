+build-backend = "uv_build"
+
+[project]
+name = "cambc-visualiser"
+version = "1.1.0"
+description = "Replay viewer and bot-state visualisation for Cambridge Battlecode"
+requires-python = ">=3.12,<3.14"
+license-files = ["LICENSE"]
+
+[project.scripts]
+conveyor-assets = "visualiser.scripts.conveyor_assets:main"
+
+[dependency-groups]
+dev = ["pillow>=11.0"]
+
+[tool.uv.build-backend]
+module-name = "visualiser"
